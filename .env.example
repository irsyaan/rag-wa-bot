# ── General ──────────────────────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=info

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_BOT_NUMBER=6281994039680
OWNER_WHATSAPP_NUMBER=6287877904270

# ── MySQL ────────────────────────────────────────────────────────────────────
# Server Docker:    host.docker.internal
# Server host:      127.0.0.1
# Local Mac:        localhost (only if MySQL runs on Mac)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=rag
MYSQL_PASSWORD=P@ssw0rd
MYSQL_DATABASE=whatsapp_rag

# ── Ollama ───────────────────────────────────────────────────────────────────
# Server Docker:    http://host.docker.internal:11434
# Server host:      http://127.0.0.1:11434
# Local Mac:        http://localhost:11434 (only if Ollama runs on Mac)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MAIN_MODEL=qwen3-8b-rag
OLLAMA_FAST_MODEL=qwen3-4b-fast
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_THINK=false

# ── Qdrant ───────────────────────────────────────────────────────────────────
# Server Docker:    http://qdrant:6333  (same compose network)
# Server host:      http://127.0.0.1:6333
# Local Mac:        http://localhost:6333 (only if Qdrant runs on Mac)
QDRANT_URL=http://qdrant:6333
QDRANT_KNOWLEDGE_COLLECTION=personal_knowledge
QDRANT_MEMORY_COLLECTION=personal_memory
QDRANT_CHAT_COLLECTION=conversation_memory
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=Cosine

# ── RAG ──────────────────────────────────────────────────────────────────────
RAG_UPLOAD_DIR=/srv/rag/personal/uploads
RAG_PROCESSED_DIR=/srv/rag/personal/processed
RAG_LOG_DIR=/srv/rag/personal/logs
RAG_MAX_RESULTS=5
RAG_SCORE_THRESHOLD=0.65

# ── Neonize ──────────────────────────────────────────────────────────────────
NEONIZE_SESSION_PATH=/srv/rag/personal/neonize-session/bot.sqlite3
